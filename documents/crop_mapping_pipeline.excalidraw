    {
      "id": "e-s3-text", "type": "text",
      "x": 948, "y": 842, "width": 358, "height": 365, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 125, "version": 1, "versionNonce": 125,
      "isDeleted": false, "boundElements": [], "updated": 1700000000000,
      "link": null, "locked": false,
      "text": "STAGE 3 -- Full Validation\n________________________________\n\nExp A:  All bands (baseline)\nExp B:  Stage 1 top-25 bands\nExp C:  Stage 2 CNN-selected\n\nEach x 3 architectures:\n  - U-Net (ResNet34/50)\n  - DeepLabV3+\n  - SegFormer\n\nFull training: 100 epochs\nPatch: 256x256  |  RTX 4090 (24GB)\n\nMetrics:\n  mIoU | Per-class IoU | F1\n  Train time | GPU memory",
      "fontSize": 12, "fontFamily": 2, "textAlign": "left",
      "verticalAlign": "top", "containerId": null,
      "originalText": "STAGE 3 -- Full Validation\n________________________________\n\nExp A:  All bands (baseline)\nExp B:  Stage 1 top-25 bands\nExp C:  Stage 2 CNN-selected\n\nEach x 3 architectures:\n  - U-Net (ResNet34/50)\n  - DeepLabV3+\n  - SegFormer\n\nFull training: 100 epochs\nPatch: 256x256  |  RTX 4090 (24GB)\n\nMetrics:\n  mIoU | Per-class IoU | F1\n  Train time | GPU memory",
      "lineHeight": 1.35
    },
